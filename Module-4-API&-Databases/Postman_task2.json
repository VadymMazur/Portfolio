    {
      "name": "CreateNewUser",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Check if response is successful (201 or 200)",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    pm.test(\"Статус-код 201 (або 200) та наявність ID\", function () {",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "        const jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property('id');",
              "    });",
              "    ",
              "    pm.test(\"Типи даних відповідають схемі\", function () {",
              "        const jsonData = pm.response.json();",
              "        pm.expect(jsonData.name).to.be.a('string');",
              "        pm.expect(jsonData.age).to.be.a('number');",
              "        pm.expect(jsonData.gender).to.be.oneOf([\"male\", \"female\"]);",
              "    });",
              "    ",
              "    // Save user ID to environment",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.id) {",
              "        pm.environment.set(\"userId\", jsonData.id);",
              "    }",
              "} else if (pm.response.code === 400) {",
              "    // Handle validation errors",
              "    pm.test(\"Помилка валідації (400)\", function () {",
              "        pm.response.to.have.status(400);",
              "        pm.expect(pm.response.text()).to.include(\"Validation error\");",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
